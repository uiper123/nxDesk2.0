diff --git a/.github/workflows/release.yml b/.github/workflows/release.yml
index 2aa5451..88c845c 100644
--- a/.github/workflows/release.yml
+++ b/.github/workflows/release.yml
@@ -108,6 +108,59 @@ jobs:
           name: server-agent-linux
           path: release-artifacts/*
 
+  build-agent-windows:
+    name: Build Server Agent (Windows x86_64)
+    needs: check-and-tag
+    if: needs.check-and-tag.outputs.should_build == 'true'
+    env:
+      RELEASE_TAG: ${{ needs.check-and-tag.outputs.tag_name }}
+    runs-on: windows-latest
+    steps:
+      - name: Checkout Repository
+        uses: actions/checkout@v4
+
+      - name: Set up Rust Toolchain
+        uses: dtolnay/rust-toolchain@stable
+
+      - name: Cache Cargo Dependencies
+        uses: actions/cache@v4
+        with:
+          path: |
+            ~/.cargo/bin/
+            ~/.cargo/registry/index/
+            ~/.cargo/registry/cache/
+            ~/.cargo/git/db/
+            target/
+          key: ${{ runner.os }}-release-cargo-${{ hashFiles('**/Cargo.lock') }}
+
+      - name: Build Server Agent Release
+        run: cargo build --release -p server-agent
+
+      - name: Prepare Agent Artifacts
+        shell: pwsh
+        run: |
+          New-Item -ItemType Directory -Force -Path release-artifacts | Out-Null
+          Copy-Item target/release/server-agent.exe release-artifacts/ttgtiso-desk-agent-windows-x86_64.exe
+          Copy-Item scripts/install-agent.ps1 release-artifacts/install-agent.ps1
+          Copy-Item scripts/uninstall-agent.ps1 release-artifacts/uninstall-agent.ps1
+          Copy-Item scripts/update-agent.ps1 release-artifacts/update-agent.ps1
+          Set-Location release-artifacts
+          $files = @(
+            "ttgtiso-desk-agent-windows-x86_64.exe",
+            "install-agent.ps1",
+            "uninstall-agent.ps1",
+            "update-agent.ps1"
+          )
+          Get-FileHash -Algorithm SHA256 $files |
+            ForEach-Object { "{0}  {1}" -f $_.Hash.ToLower(), (Split-Path $_.Path -Leaf) } |
+            Set-Content SHA256SUMS-windows.txt
+
+      - name: Upload Agent Artifacts
+        uses: actions/upload-artifact@v4
+        with:
+          name: server-agent-windows
+          path: release-artifacts/*
+
   build-desktop-client:
