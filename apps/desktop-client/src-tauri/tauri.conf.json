{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "appsdesktop-client",
  "version": "0.1.1",
  "identifier": "com.ttgtiso.desk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "appsdesktop-client",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4OUNFMDAyRTlGMTlEN0QKUldSOW5mSHBBdUNjR0ZQekhxQUlyNXFlQ1c5Zm5iNFVVSFJhZFphV0ZKZFZvTTlYaHdtL2FuNzIK",
      "endpoints": [
        "https://github.com/uiper123/nxDesk2.0/releases/latest/download/latest.json"
      ]
    }
  }
}
